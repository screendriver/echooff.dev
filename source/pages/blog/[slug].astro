---
import { Image } from "astro:assets";
import { Schema } from "astro-seo-schema";
import { getCollection, render } from "astro:content";
import BlogBackLink from "../../blog/BlogBackLink.astro";
import BlogMetadata from "../../blog/BlogMetadata.astro";
import BlogPostContent from "../../blog/BlogPostContent.astro";
import BlogShell from "../../blog/BlogShell.astro";
import BlogTopicLink from "../../blog/BlogTopicLink.astro";
import HackerNewsMentions from "../../blog/HackerNewsMentions.astro";
import LocalizedDateTime from "../../blog/LocalizedDateTime.astro";
import LocalizedDateTimeScript from "../../blog/LocalizedDateTimeScript.astro";
import Webmentions from "../../blog/Webmentions.astro";
import { getBlogPostTopicDetails } from "../../blog/blog-post-topics.js";
import {
	createBlogPostPageTitle,
	createBlogPostReadingTimeLabel,
	sortBlogPostsByPublicationDateDescending
} from "../../blog/blog-posts.js";
import {
	createAbsoluteAssetUrl,
	createBlogPostAbsoluteUrl,
	createBlogRssFeedAbsoluteUrl,
	getConfiguredSiteUrlOrThrow
} from "../../blog/blog-site.js";
import {
	createEmptyHackerNewsSectionModel,
	loadHackerNewsMentionsForTargetUrl
} from "../../blog/hacker-news-mentions.js";
import { createEmptyWebmentionSectionModel, loadWebmentionsForTargetUrl } from "../../blog/webmentions.js";
import aboutImage from "../../assets/images/about.jpg";
import headerImage from "../../assets/images/header-01.jpg";

export async function getStaticPaths() {
	const blogPosts = sortBlogPostsByPublicationDateDescending(await getCollection("blog"));

	return blogPosts.map((blogPost) => ({
		params: {
			slug: blogPost.id
		},
		props: {
			blogPost
		}
	}));
}

const { blogPost } = Astro.props;
const { Content } = await render(blogPost);
const configuredSiteUrl = getConfiguredSiteUrlOrThrow(Astro.site);
const blogPostUrl = createBlogPostAbsoluteUrl(configuredSiteUrl, blogPost.id);
const blogRssFeedUrl = createBlogRssFeedAbsoluteUrl(configuredSiteUrl);
const openGraphImageUrl = createAbsoluteAssetUrl(configuredSiteUrl, headerImage.src);
const openGraphImageAlternativeText = "echooff.dev header illustration";
const topicDetails = getBlogPostTopicDetails(blogPost.data.topic);
const blogPostReadingTimeLabel = createBlogPostReadingTimeLabel(blogPost.body ?? "");
const siteUrl = configuredSiteUrl.toString();
let webmentionSectionModel = createEmptyWebmentionSectionModel();
let hackerNewsSectionModel = createEmptyHackerNewsSectionModel();

try {
	webmentionSectionModel = await loadWebmentionsForTargetUrl(
		{
			fetch
		},
		blogPostUrl
	);
} catch (error: unknown) {
	console.warn(`Unable to load webmentions for "${blogPostUrl}" during build`, error);
}

try {
	hackerNewsSectionModel = await loadHackerNewsMentionsForTargetUrl(
		{
			fetch
		},
		blogPostUrl
	);
} catch (error: unknown) {
	console.warn(`Unable to load Hacker News mentions for "${blogPostUrl}" during build`, error);
}
---

<BlogShell
	canonicalUrl={blogPostUrl}
	description={blogPost.data.description}
	openGraphImageAlternativeText={openGraphImageAlternativeText}
	openGraphImageUrl={openGraphImageUrl}
	openGraphPublishedTime={blogPost.data.publishedAt}
	openGraphType="article"
	openGraphUrl={blogPostUrl}
	rssFeedUrl={blogRssFeedUrl}
	robots="index,follow,max-image-preview:large"
	title={createBlogPostPageTitle(blogPost.data.title)}
	twitterCardType="summary_large_image"
	pageTitle="Blog"
	showPageHeader={false}
>
	<Fragment slot="search-engine-optimization-schema">
		<Schema
			item={{
				"@context": "https://schema.org",
				"@type": "BlogPosting",
				author: {
					"@type": "Person",
					name: "Christian Rackerseder",
					url: siteUrl
				},
				datePublished: blogPost.data.publishedAt,
				description: blogPost.data.description,
				headline: blogPost.data.title,
				image: openGraphImageUrl,
				articleSection: topicDetails.label,
				mainEntityOfPage: blogPostUrl,
				publisher: {
					"@type": "Person",
					name: "Christian Rackerseder",
					url: siteUrl
				},
				url: blogPostUrl
			}}
		/>
	</Fragment>

	<article class="blog-post-article h-entry">
		<header class="blog-post-article-header">
			<div class="blog-post-article-top-row">
				<nav aria-label="Blog">
					<BlogBackLink href="/blog" includeIcon>Back to Blog</BlogBackLink>
				</nav>

				<figure class="blog-post-article-avatar h-card">
					<a class="u-url" href={siteUrl}>
						<Image
							alt="Christian Rackerseder"
							class="blog-post-article-avatar-image u-photo"
							height={88}
							src={aboutImage}
							quality={75}
							width={88}
						/>
					</a>
					<span class="blog-post-screen-reader-only p-name">Christian Rackerseder</span>
				</figure>
			</div>
			<h1 class="p-name">{blogPost.data.title}</h1>
			<BlogMetadata>
				Published{" "}
				<LocalizedDateTime className="dt-published" publishedAt={blogPost.data.publishedAt} />{" "}
				in <BlogTopicLink href={`/blog/topics/${topicDetails.slug}`}>{topicDetails.label}</BlogTopicLink>
				<span class="blog-post-article-metadata-separator" aria-hidden="true">
					{" "}·{" "}
				</span>
				<span class="blog-post-article-reading-time">{blogPostReadingTimeLabel}</span>
			</BlogMetadata>
			<a class="u-url blog-post-screen-reader-only" href={blogPostUrl}> Permalink </a>
		</header>

		<BlogPostContent>
			<Content />
		</BlogPostContent>

		<Webmentions webmentionSectionModel={webmentionSectionModel} />
		<HackerNewsMentions hackerNewsSectionModel={hackerNewsSectionModel} />
	</article>

	<LocalizedDateTimeScript />
</BlogShell>

<style lang="scss">
	@use "../../styles/variables";

	.blog-post-article {
		padding: 1.5rem;
	}

	.blog-post-article-header {
		border-bottom: 1px solid rgba(variables.$selection, 0.8);
		margin-bottom: 1.25rem;
		padding-bottom: 1rem;
	}

	.blog-post-article-top-row {
		align-items: flex-start;
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		margin-bottom: 1rem;
	}

	.blog-post-article-avatar {
		flex-shrink: 0;
	}

	.blog-post-article-avatar-image {
		border: 4px solid variables.$comment;
		border-radius: 9999px;
		display: block;
		height: 5.5rem;
		width: 5.5rem;
	}

	.blog-post-screen-reader-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.blog-post-article-metadata-separator {
		color: rgba(variables.$foreground, 0.3);
	}

	.blog-post-article-reading-time {
		letter-spacing: -0.01em;
		white-space: nowrap;
	}

	h1 {
		color: variables.$foreground;
		font-size: clamp(1.75rem, 3vw, 2.35rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.1;
		margin-bottom: 0.75rem;
	}

	@media (min-width: variables.$small-width) {
		.blog-post-article {
			padding-left: 2rem;
			padding-right: 2rem;
		}
	}
</style>
