---
import { getCollection } from "astro:content";
import BlogArchiveList from "../../../blog/BlogArchiveList.astro";
import BlogArchiveNavigation from "../../../blog/BlogArchiveNavigation.astro";
import BlogArchiveSection from "../../../blog/BlogArchiveSection.astro";
import BlogBackLink from "../../../blog/BlogBackLink.astro";
import BlogEmptyState from "../../../blog/BlogEmptyState.astro";
import BlogIndexEntry from "../../../blog/BlogIndexEntry.astro";
import BlogShell from "../../../blog/BlogShell.astro";
import LocalizedDateTime from "../../../blog/LocalizedDateTime.astro";
import LocalizedDateTimeScript from "../../../blog/LocalizedDateTimeScript.astro";
import { createBlogIndexEntries, sortBlogPostsByPublicationDateDescending } from "../../../blog/blog-posts.js";
import { createBlogPostTopicArchiveEntries, groupBlogPostsByTopic } from "../../../blog/blog-post-topics.js";
import {
	createAbsoluteAssetUrl,
	createBlogRssFeedAbsoluteUrl,
	createBlogTopicAbsoluteUrl
} from "../../../blog/blog-site.js";
import headerImage from "../../../assets/images/header-01.jpg";

export async function getStaticPaths() {
	const blogPosts = await getCollection("blog");
	const topicArchiveEntries = createBlogPostTopicArchiveEntries(blogPosts);
	const blogPostsByTopic = groupBlogPostsByTopic(blogPosts);

	return topicArchiveEntries.map((topicArchiveEntry) => ({
		params: {
			topic: topicArchiveEntry.slug
		},
		props: {
			blogPosts: sortBlogPostsByPublicationDateDescending(blogPostsByTopic.get(topicArchiveEntry.label) ?? []),
			topicArchiveEntry
		}
	}));
}

const { blogPosts, topicArchiveEntry } = Astro.props;
const blogIndexEntries = createBlogIndexEntries(blogPosts);
const topicArchiveUrl = createBlogTopicAbsoluteUrl(Astro.site, topicArchiveEntry.slug);
const blogRssFeedUrl = createBlogRssFeedAbsoluteUrl(Astro.site);
const openGraphImageUrl = createAbsoluteAssetUrl(Astro.site, headerImage.src);
const openGraphImageAlternativeText = "echooff.dev header illustration";
const pageTitle = `${topicArchiveEntry.label} Posts`;
const postCountLabel =
	topicArchiveEntry.postCount === 1 ? "1 post available" : `${topicArchiveEntry.postCount} posts available`;
---

<BlogShell
	canonicalUrl={topicArchiveUrl}
	description={topicArchiveEntry.description}
	openGraphImageAlternativeText={openGraphImageAlternativeText}
	openGraphImageUrl={openGraphImageUrl}
	openGraphPublishedTime=""
	openGraphType="website"
	openGraphUrl={topicArchiveUrl}
	rssFeedUrl={blogRssFeedUrl}
	robots="index,follow,max-image-preview:large"
	title={`${pageTitle} | Christian Rackerseder`}
	twitterCardType="summary_large_image"
	pageTitle={pageTitle}
	intro={topicArchiveEntry.description}
	terminalCommand={`$ ls /blog/topics/${topicArchiveEntry.slug}`}
	terminalOutput={postCountLabel}
>
	<BlogArchiveSection label={`Blog posts in ${topicArchiveEntry.label}`}>
		<BlogArchiveNavigation>
			<BlogBackLink href="/blog/topics">Back to Blog Topics</BlogBackLink>
		</BlogArchiveNavigation>

		{
			blogIndexEntries.length > 0 ? (
				<BlogArchiveList>
					{blogIndexEntries.map((blogIndexEntry) => (
						<li>
							<BlogIndexEntry
								description={blogIndexEntry.description}
								href={`/blog/${blogIndexEntry.slug}`}
								title={blogIndexEntry.title}
							>
								<Fragment slot="footer">
									Published <LocalizedDateTime publishedAt={blogIndexEntry.publishedAt} />
								</Fragment>
							</BlogIndexEntry>
						</li>
					))}
				</BlogArchiveList>
			) : (
				<BlogEmptyState>No blog posts published for this topic yet.</BlogEmptyState>
			)
		}
	</BlogArchiveSection>

	<LocalizedDateTimeScript />
</BlogShell>
