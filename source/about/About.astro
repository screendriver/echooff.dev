---
import { icons } from "feather-icons";
import { Image } from "astro:assets";
import aboutImage from "../assets/images/about.jpg";
---

<section>
	<h2>
		About
		<Fragment set:html={icons.info?.toSvg()} />
	</h2>

	<hr />

	<article>
		<p>
			JavaScript is everywhere. In the old days, being a JavaScript developer meant that you were a front end web
			developer. Forever bound to the browser.
		</p>

		<strong>Those days are gone</strong>

		<p>
			The rise of Node.js ushered in a new era. An era where being a JavaScript developer doesn’t necessarily mean
			a front-end web developer. As a JavaScript developer today, you can target more platforms than any other
			high level language.
		</p>

		<figure>
			<Image alt="My face" src={aboutImage} width={300} height={300} quality={75} class="about-image" />
		</figure>
	</article>
</section>

<style lang="scss">
	@use "../styles/variables";
	@use "../styles/mixins";

	section {
		background-color: variables.$selection;
		padding: 1rem;

		@media (min-width: variables.$large-width) {
			padding: 2rem 2.5rem;
		}
	}

	h2 {
		@include mixins.heading;

		:global(svg) {
			@include mixins.heading-icon;
		}
	}

	hr {
		@include mixins.divider;
	}

	article {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: justify;
		gap: 0;

		@media (min-width: variables.$small-width) {
			padding: 1rem;
		}

		@media (min-width: variables.$large-width) {
			display: grid;
			grid-template-columns: minmax(0, 38rem) auto;
			column-gap: 1.75rem;
			align-items: center;
			justify-content: center;
			max-width: variables.$large-width;
			margin: auto;
			padding: 0.75rem 1.75rem 1.25rem;
		}

		@media (min-width: variables.$extra-large-width) {
			padding-left: 2.75rem;
			padding-right: 2.75rem;
		}
	}

	p {
		margin: auto;

		@media (min-width: variables.$large-width) {
			text-align: left;
			width: 100%;
		}
	}

	strong {
		margin-top: 1.25rem;
		margin-bottom: 1.25rem;
		display: block;
		text-align: center;
		text-transform: uppercase;

		@media (min-width: variables.$large-width) {
			text-align: left;
		}
	}

	figure {
		margin-top: 1.75rem;
		margin-bottom: 1.5rem;

		@media (min-width: variables.$medium-width) {
			margin-bottom: 0.75rem;
		}

		@media (min-width: variables.$large-width) {
			grid-column: 2;
			grid-row: 1 / span 3;
			margin-top: 0;
			margin-bottom: 0;
		}
	}

	.about-image {
		border-color: variables.$comment;
		height: 10rem;
		width: 10rem;
		border-radius: 9999px;
		border-width: 4px;
		border-style: solid;

		@media (min-width: variables.$large-width) {
			height: 9rem;
			width: 9rem;
		}
	}
</style>
