---
export interface Props {
	readonly description: string;
	readonly href: string;
	readonly postCount: number;
	readonly title: string;
}

const { description, href, postCount, title } = Astro.props;
const postCountLabel = postCount === 1 ? "1 post" : `${postCount} posts`;
---

<article>
	<a class="topic-archive-link" href={href}>
		<h2 class="topic-archive-title">{title}</h2>
		<p class="topic-archive-description">{description}</p>
		<footer class="topic-archive-post-count">{postCountLabel}</footer>
	</a>
</article>

<style lang="scss">
	@use "../styles/variables";
	@use "../styles/mixins";
	@use "sass:color";

	.topic-archive-link {
		border: 1px solid rgba(variables.$selection, 0.85);
		border-radius: 0.5rem;
		background-color: rgba(variables.$background, 0.4);
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1rem;
	}

	.topic-archive-title {
		color: variables.$foreground;
		font-size: clamp(1.15rem, 2vw, 1.3rem);
		font-weight: 700;
		line-height: 1.25;
		text-decoration: underline;
		text-decoration-color: transparent;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.16em;
		transition:
			color 160ms ease-in-out,
			text-decoration-color 160ms ease-in-out;
	}

	.topic-archive-link:hover .topic-archive-title,
	.topic-archive-link:focus-visible .topic-archive-title {
		color: variables.$cyan;
		text-decoration-color: rgba(variables.$cyan, 0.55);
	}

	.topic-archive-description {
		color: color.mix(variables.$foreground, variables.$comment, $weight: 72%);
		font-size: 0.94rem;
		line-height: 1.55;
		max-width: 40rem;
		transition: color 160ms ease-in-out;
		@include mixins.clamp-to-lines(2);
	}

	.topic-archive-post-count {
		color: rgba(variables.$foreground, 0.46);
		font-size: 0.82rem;
	}
</style>
