---
import BlogEmptyState from "./BlogEmptyState.astro";
import CommentIcon from "./CommentIcon.astro";
import ScoreIcon from "./ScoreIcon.astro";
import { formatPublishedAtFallbackDateTime } from "./blog-posts.js";
import type { HackerNewsSectionModel } from "./hacker-news-mentions.js";

export interface Props {
	readonly hackerNewsSectionModel: HackerNewsSectionModel;
}

const { hackerNewsSectionModel } = Astro.props;
---

{hackerNewsSectionModel.mentions.length === 0 && <BlogEmptyState>No public Hacker News mentions yet.</BlogEmptyState>}

{
	hackerNewsSectionModel.mentions.length > 0 && (
		<ul>
			{hackerNewsSectionModel.mentions.map((hackerNewsMention) => (
				<li>
					<article>
						<header>
							<h3>
								<a href={hackerNewsMention.discussionUrl}>{hackerNewsMention.storyTitle}</a>
							</h3>
							<dl class="mention-metadata-list">
								<dt class="screen-reader-only">Score</dt>
								<dd class="meta-pill">
									<ScoreIcon />
									<span>{hackerNewsMention.pointCount} points</span>
								</dd>
								<dt class="screen-reader-only">Comments</dt>
								<dd class="meta-pill">
									<CommentIcon />
									<span>{hackerNewsMention.commentCount} comments</span>
								</dd>
								{hackerNewsMention.visiblePublishedAt.isJust && (
									<>
										<dt class="meta-date-label">Published</dt>
										<dd class="meta-date-value">
											<time datetime={hackerNewsMention.visiblePublishedAt.value}>
												{formatPublishedAtFallbackDateTime(
													hackerNewsMention.visiblePublishedAt.value
												)}
											</time>
										</dd>
									</>
								)}
							</dl>
						</header>
						<footer>
							<a href={hackerNewsMention.discussionUrl}>View discussion</a>
						</footer>
					</article>
				</li>
			))}
		</ul>
	)
}

<style lang="scss">
	@use "../styles/variables";

	ul {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 1.25rem;
	}

	li {
		background-color: rgba(variables.$background, 0.45);
		border: 1px solid rgba(variables.$selection, 0.85);
		border-radius: 0.5rem;
		padding: 1rem;
	}

	h3 a {
		color: variables.$foreground;
		font-weight: 700;
	}

	.mention-metadata-list,
	footer {
		color: rgba(variables.$foreground, 0.46);
		font-size: 0.82rem;
		margin-top: 0.4rem;
	}

	.mention-metadata-list {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.screen-reader-only {
		border: 0 !important;
		clip: rect(0 0 0 0) !important;
		clip-path: inset(50%) !important;
		height: 1px !important;
		margin: -1px !important;
		overflow: hidden !important;
		padding: 0 !important;
		position: absolute !important;
		white-space: nowrap !important;
		width: 1px !important;
	}

	.meta-pill {
		align-items: center;
		background-color: rgba(variables.$selection, 0.4);
		border: 1px solid rgba(variables.$selection, 0.9);
		border-radius: 9999px;
		color: variables.$yellow;
		display: inline-flex;
		gap: 0.35rem;
		padding: 0.15rem 0.45rem;
		margin: 0;
	}

	.meta-date-label,
	.meta-date-value {
		display: inline;
		margin: 0;
	}

	.meta-date-label::after {
		content: ": ";
	}
</style>
