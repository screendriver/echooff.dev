---
import { formatDateTimeFallback } from "./blog-posts.js";

export interface Props {
	readonly className?: string;
	readonly dateTime: string;
}

const { className, dateTime } = Astro.props;
const fallbackDateTime = formatDateTimeFallback(dateTime);
---

<time
	class:list={["localized-date-time", "localized-date-time-pending", className]}
	datetime={dateTime}
	data-localized-date-time
>
	{fallbackDateTime}
</time>

<noscript>
	<style>
		.localized-date-time-pending {
			visibility: visible;
		}
	</style>
</noscript>

<style>
	.localized-date-time-pending {
		visibility: hidden;
	}
</style>
