---
import { formatPublishedAtFallbackDateTime } from "./blog-posts.js";

export interface Props {
	readonly className?: string;
	readonly publishedAt: string;
}

const { className, publishedAt } = Astro.props;
const fallbackPublishedAtDateTime = formatPublishedAtFallbackDateTime(publishedAt);
---

<time
	class:list={["localized-date-time", "localized-date-time-pending", className]}
	datetime={publishedAt}
	data-localized-date-time
>
	{fallbackPublishedAtDateTime}
</time>

<noscript>
	<style>
		.localized-date-time-pending {
			visibility: visible;
		}
	</style>
</noscript>

<style>
	.localized-date-time-pending {
		visibility: hidden;
	}
</style>
