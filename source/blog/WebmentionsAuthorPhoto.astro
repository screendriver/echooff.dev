---
import type { WebmentionReply } from "./webmentions.js";

export interface Props {
	readonly webmentionReply: WebmentionReply;
}

const { webmentionReply } = Astro.props;
---

{
	webmentionReply.author.photoUrl.isJust && (
		<img
			class="webmention-author-photo"
			src={webmentionReply.author.photoUrl.value}
			alt=""
			loading="lazy"
			decoding="async"
			width="56"
			height="56"
		/>
	)
}

<style lang="scss">
	@use "../styles/variables";

	.webmention-author-photo {
		border: 2px solid rgba(variables.$selection, 0.9);
		border-radius: 9999px;
		flex-shrink: 0;
		height: 3.5rem;
		object-fit: cover;
		width: 3.5rem;
	}
</style>
