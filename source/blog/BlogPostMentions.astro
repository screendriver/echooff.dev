---
import { createWallClock } from "@enormora/wall-clock";
import HackerNewsMentions from "./HackerNewsMentions.astro";
import Webmentions from "./Webmentions.astro";
import { createBlogPostAbsoluteUrl } from "./blog-site.js";
import {
	loadBlogPostMentionsForTargetUrl,
	runtimeMentionRequestTimeoutMilliseconds
} from "./runtime-blog-post-mentions.js";
import {
	createDisabledMentionCacheRepository,
	readRuntimeMentionCacheRepositoryTask
} from "./runtime-mention-cache-repository.js";
import { standardStreamRuntimeLogger } from "./runtime-logger.js";

export interface Props {
	readonly blogPostId: string;
}

const systemWallClock = createWallClock();
const { blogPostId } = Astro.props;
const blogPostUrl = createBlogPostAbsoluteUrl(Astro.site, blogPostId);
const mentionCacheRepository = await (async () => {
	if (import.meta.env.DEV) {
		return createDisabledMentionCacheRepository();
	}

	const repositoryResult = await readRuntimeMentionCacheRepositoryTask();

	return repositoryResult.match({
		Err(error) {
			standardStreamRuntimeLogger.warn("Unable to open mention cache database", error, {
				event: "mention_cache_database_open_failed"
			});

			return createDisabledMentionCacheRepository();
		},
		Ok(repository) {
			return repository;
		}
	});
})();

Astro.response.headers.set("Cache-Control", "public, max-age=300, stale-while-revalidate=3600");

const { hackerNewsSectionModel, webmentionSectionModel } = await loadBlogPostMentionsForTargetUrl(
	{
		createTimeoutSignal(timeoutMilliseconds) {
			return AbortSignal.timeout(timeoutMilliseconds);
		},
		fetch,
		logInfo: standardStreamRuntimeLogger.info,
		logWarning: standardStreamRuntimeLogger.warn,
		mentionCacheRepository,
		requestTimeoutMilliseconds: runtimeMentionRequestTimeoutMilliseconds,
		wallClock: systemWallClock
	},
	blogPostUrl
);
---

<Webmentions webmentionSectionModel={webmentionSectionModel} />
<HackerNewsMentions hackerNewsSectionModel={hackerNewsSectionModel} />
