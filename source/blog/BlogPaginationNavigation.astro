---
import type { BlogPaginationModel } from "./blog-pagination.ts";

export interface Props {
	readonly paginationModel: BlogPaginationModel;
}

const { paginationModel } = Astro.props;
---

{
	paginationModel.lastPage > 1 && (
		<nav class="blog-pagination-navigation" aria-label="Blog archive pagination">
			<div class="blog-pagination-navigation-summary">
				<p class="blog-pagination-navigation-page-count">{paginationModel.pageCountLabel}</p>
				<p class="blog-pagination-navigation-results">{paginationModel.resultsLabel}</p>
			</div>

			<div class="blog-pagination-navigation-links">
				{paginationModel.previousPageHref ? (
					<a class="blog-pagination-navigation-link" href={paginationModel.previousPageHref}>
						Previous
					</a>
				) : (
					<span class="blog-pagination-navigation-link is-disabled" aria-disabled="true">
						Previous
					</span>
				)}

				<ol class="blog-pagination-navigation-page-list">
					{paginationModel.pageLinks.map((pageLink) => (
						<li>
							{pageLink.isCurrent ? (
								<span class="blog-pagination-navigation-page-link is-current" aria-current="page">
									{pageLink.pageNumber}
								</span>
							) : (
								<a class="blog-pagination-navigation-page-link" href={pageLink.href}>
									{pageLink.pageNumber}
								</a>
							)}
						</li>
					))}
				</ol>

				{paginationModel.nextPageHref ? (
					<a class="blog-pagination-navigation-link" href={paginationModel.nextPageHref}>
						Next
					</a>
				) : (
					<span class="blog-pagination-navigation-link is-disabled" aria-disabled="true">
						Next
					</span>
				)}
			</div>
		</nav>
	)
}

<style lang="scss">
	@use "../styles/variables";

	.blog-pagination-navigation {
		border-top: 1px solid rgba(variables.$selection, 0.8);
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-top: 0.25rem;
		padding-top: 1.1rem;
	}

	.blog-pagination-navigation-summary {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.blog-pagination-navigation-page-count {
		color: variables.$foreground;
		font-size: 0.9rem;
	}

	.blog-pagination-navigation-results {
		color: rgba(variables.$foreground, 0.52);
		font-size: 0.8rem;
	}

	.blog-pagination-navigation-links {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: space-between;
	}

	.blog-pagination-navigation-link,
	.blog-pagination-navigation-page-link {
		color: variables.$cyan;
		text-decoration: underline;
		text-decoration-color: rgba(variables.$cyan, 0.5);
		text-underline-offset: 0.18rem;
	}

	.blog-pagination-navigation-link:hover,
	.blog-pagination-navigation-link:focus-visible,
	.blog-pagination-navigation-page-link:hover,
	.blog-pagination-navigation-page-link:focus-visible {
		color: variables.$pink;
	}

	.blog-pagination-navigation-link.is-disabled {
		color: rgba(variables.$foreground, 0.3);
		text-decoration: none;
	}

	.blog-pagination-navigation-page-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.blog-pagination-navigation-page-link {
		border: 1px solid rgba(variables.$selection, 0.95);
		border-radius: 0.35rem;
		display: inline-flex;
		min-width: 2rem;
		justify-content: center;
		padding: 0.2rem 0.5rem;
	}

	.blog-pagination-navigation-page-link.is-current {
		background-color: rgba(variables.$selection, 0.95);
		color: variables.$yellow;
		text-decoration: none;
	}

	@media (max-width: variables.$small-width) {
		.blog-pagination-navigation-links {
			align-items: stretch;
			display: grid;
			gap: 0.9rem;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			grid-template-areas:
				"pages pages"
				"previous next";
		}

		.blog-pagination-navigation-page-list {
			grid-area: pages;
			justify-content: center;
		}

		.blog-pagination-navigation-links > :first-child {
			grid-area: previous;
		}

		.blog-pagination-navigation-links > :last-child {
			grid-area: next;
			justify-self: end;
		}
	}
</style>
