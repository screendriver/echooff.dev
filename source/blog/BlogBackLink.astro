---
import { icons } from "feather-icons";

export interface Props {
	readonly href: string;
	readonly includeIcon?: boolean;
}

const { href, includeIcon = false } = Astro.props;
---

<a class="blog-back-link" href={href}>
	{includeIcon && <Fragment set:html={icons["arrow-left"]?.toSvg({ class: "blog-back-link-icon" })} />}
	<span><slot /></span>
</a>

<style lang="scss">
	@use "../styles/variables";

	.blog-back-link {
		align-items: center;
		color: variables.$cyan;
		display: inline-flex;
		font-size: 0.9rem;
		gap: 0.45rem;
		text-decoration: underline;
		text-decoration-color: rgba(variables.$cyan, 0.5);
		text-underline-offset: 0.2rem;
	}

	.blog-back-link :global(.blog-back-link-icon) {
		height: 1rem;
		width: 1rem;
	}

	.blog-back-link:hover,
	.blog-back-link:focus-visible {
		color: variables.$pink;
	}
</style>
