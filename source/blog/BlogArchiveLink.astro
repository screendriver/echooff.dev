---
export interface Props {
	readonly href: string;
}

const { href } = Astro.props;
---

<a class="blog-archive-link" href={href}><span><slot /></span></a>

<style lang="scss">
	@use "../styles/variables";

	.blog-archive-link {
		color: variables.$cyan;
		text-decoration: none;
	}

	@media (min-width: variables.$small-width) {
		.blog-archive-link::before {
			color: variables.$foreground;
			content: "·";
			margin-inline-end: 0.75rem;
		}
	}

	.blog-archive-link:hover,
	.blog-archive-link:focus-visible {
		color: variables.$pink;
	}

	.blog-archive-link:hover > span,
	.blog-archive-link:focus-visible > span {
		text-decoration: underline;
		text-decoration-color: rgba(variables.$pink, 0.55);
		text-underline-offset: 0.2rem;
	}
</style>
