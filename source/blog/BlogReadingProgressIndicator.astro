<div class="blog-reading-progress-indicator" aria-hidden="true">
	<div class="blog-reading-progress-indicator-fill" data-blog-reading-progress-indicator-fill></div>
</div>

<script>
	import { initializeReadingProgressIndicator } from "./reading-progress.js";

	const progressIndicatorFillElement = document.querySelector("[data-blog-reading-progress-indicator-fill]");

	if (progressIndicatorFillElement instanceof HTMLElement) {
		initializeReadingProgressIndicator({
			readDocumentScrollHeight() {
				return document.documentElement.scrollHeight;
			},
			readVerticalScrollOffset() {
				return window.scrollY;
			},
			readViewportHeight() {
				return window.innerHeight;
			},
			registerResizeListener(listener: () => void) {
				window.addEventListener("resize", listener, { passive: true });
			},
			registerScrollListener(listener: () => void) {
				window.addEventListener("scroll", listener, { passive: true });
			},
			writeProgressPercentage(progressPercentage: number) {
				progressIndicatorFillElement.style.width = `${progressPercentage}%`;
			}
		});
	}
</script>

<style lang="scss">
	@use "../styles/variables";

	.blog-reading-progress-indicator {
		position: fixed;
		inset: 0 0 auto;
		height: 0.375rem;
		width: 100%;
		background-color: rgba(variables.$selection, 0.9);
		z-index: 1000;
	}

	.blog-reading-progress-indicator-fill {
		height: 100%;
		width: 0;
		background-image: linear-gradient(90deg, variables.$cyan, variables.$purple);
		box-shadow: 0 0 1rem rgba(variables.$cyan, 0.55);
	}
</style>
