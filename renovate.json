{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"dependencyDashboard": true,
	"labels": ["renovate"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true
	},
	"packageRules": [
		{
			"matchManagers": ["woodpecker"],
			"matchPackageNames": ["node"],
			"enabled": false
		},
		{
			"groupName": "Astro dependencies",
			"groupSlug": "astro-dependencies",
			"matchPackageNames": ["@astrojs/*", "astro", "astro-*", "*-astro"]
		},
		{
			"groupName": "Hono dependencies",
			"groupSlug": "hono-dependencies",
			"matchPackageNames": ["hono", "@hono/*"]
		},
		{
			"matchFileNames": [".woodpecker/*.yaml"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"matchPackageNames": ["eslint", "@enormora/eslint-config-*"],
			"groupName": "eslint packages"
		},
		{
			"matchDepTypes": ["dependencies", "devDependencies"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"groupName": "Node.js",
			"groupSlug": "nodejs",
			"matchPackageNames": ["node"],
			"automerge": false
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/^\\.woodpecker\\/deploy\\.yaml$/", "/^\\.woodpecker\\/test\\.yaml$/"],
			"matchStrings": ["image:\\s*node:(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
			"depNameTemplate": "node",
			"datasourceTemplate": "node",
			"versioningTemplate": "node"
		}
	]
}
